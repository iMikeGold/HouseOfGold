# ===========================
# .gitignore rules v1.0 g01dn
# ===========================

# =========================
# Dependencies
# =========================
node_modules/
/.pnp
.pnp.*
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================
# Next.js
# =========================
.next/
out/
build/

# =========================
# Logs
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Environment variables
# =========================
.env
.env.*
!.env.example

# =========================
# OS junk
# =========================
.DS_Store
Thumbs.db

# =========================
# TypeScript
# =========================
*.tsbuildinfo
next-env.d.ts

# =========================
# Testing / Coverage
# =========================
coverage/

# =========================
# Deployment
# =========================
.vercel/
.open-next/
.wrangler/
.cloudflare/

# =========================
# Large media / assets (IMPORTANT for your project)
# =========================
# Prevent accidental commits of heavy room assets
*.mp4
*.mov
*.avi
*.mkv
*.wav
*.aiff
*.psd
*.blend

# Optional: if you later store huge room renders locally
/house/assets/generated/
/house/cache/

# =========================
# Local development
# =========================
*.local
*.tmp
*.bak
